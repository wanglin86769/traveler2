{
  "port": 3000,
  "env": "development",
  "cors": {
    "origin": "http://localhost:5173",
    "credentials": true,
    "methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH"
    ],
    "allowedHeaders": [
      "Content-Type",
      "Authorization"
    ]
  },
  "rateLimit": {
    "windowMs": 900000,
    "max": 10000
  }
}