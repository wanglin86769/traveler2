{
  "jwt": {
    "secret": "your-secret-jwt-key",
    "expiresIn": "24h"
  },
  "ldap": {
    "enabled": false,
    "url": "ldap://ldap.example.com",
    "adminDn": "cn=admin,dc=ldap,dc=example,dc=com",
    "adminPassword": "your-secret-admin-pwd",
    "searchBase": "ou=users,dc=csns,dc=ihep,dc=ac,dc=cn",
    "searchFilter": "(&(objectClass=inetOrgPerson)(uid=_id))",
    "objAttributes": "displayName,mail"
  },
  "local": {
    "enabled": true
  }
}